# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api

# Database (for Drizzle migrations — direct Postgres URL from Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# API
JWT_SECRET=generate-a-long-random-string-here
API_PORT=3000
NODE_ENV=development

# Cloudflare R2 (photos)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rivals-proofs
R2_PUBLIC_BASE_URL=https://your-r2-public-domain

# Observability
SENTRY_DSN=

# Push (Phase 5)
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
